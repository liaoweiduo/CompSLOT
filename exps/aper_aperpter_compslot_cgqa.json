{
    "prefix": "",
    "dataset": "cfst_cgqa",
    "comp_test": false,
    "memory_size": 0,
    "memory_per_class": 0,
    "fixed_memory": false,
    "shuffle": true,
    "init_cls": 10,
    "increment": 10,
    "model_name": "aper_adapter",
