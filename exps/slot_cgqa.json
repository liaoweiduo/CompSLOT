{
    "prefix": "cgqa_teacher",
    "project_name": "slots",
    "dataset": "cfst_cgqa",
    "comp_test": false,
    "memory_size": 0,
    "memory_per_class": 0,
    "fixed_memory": false,
    "shuffle": true,
    "init_cls": 10,
    "increment": 10,
    "max_task": -1,
    "model_name": "slot",
    "backbone_type": "vit_base_patch16_224",
    "device": ["0"],
    "seed": [100, 200, 300, 400, 500],
    
    "tuned_epoch": 50,
    "init_lr": 1e-4,
    "lr_task_wise_decay": 0.1,
    "batch_size": 256,
    "weight_decay": 0,
    "min_lr": 1e-8,
    "optimizer": "adam",
    "scheduler": "cosine",
    "reinit_optimizer": true,
    "resume": true,

    "slot_dim": 128, 
    "fix_prompt_size": true, 
    "n_slots": 10, 
    "n_iter": 5, 
    "slot_temp": 1, 
    "decoder_mapping_layers": 3,
    "selector_mode": "attn", 
    "aggregation_mode": "soft",
    "select_slot_temp": 100, 

    "use_p_reg": true,
    "p_reg_coeff": 10,
    "p_reg_temp": 10,
    "p_reg_sim_mode": "cos",

    "pretrained": true
}